# =============================================================================
# Vercel KV (auto-populated when you create a KV database on Vercel)
# https://vercel.com/docs/storage/vercel-kv
# =============================================================================
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# =============================================================================
# OpenAI (for AI caption generation)
# https://platform.openai.com/api-keys
# =============================================================================
OPENAI_API_KEY=

# =============================================================================
# Facebook / Instagram App Credentials
# https://developers.facebook.com/apps/
# =============================================================================
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# =============================================================================
# TikTok App Credentials
# https://developers.tiktok.com/
# =============================================================================
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# =============================================================================
# Pinterest App Credentials
# https://developers.pinterest.com/
# =============================================================================
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=

# =============================================================================
# App Configuration
# =============================================================================

# Your Vercel deployment URL (used for OAuth redirect URIs)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
