# =============================================
# Luxemia Social - Environment Variables
# =============================================

# --- OpenAI API Key (required for caption generation) ---
OPENAI_API_KEY=sk-...

# --- Vercel KV (required for session persistence & history) ---
KV_REST_API_URL=https://...
KV_REST_API_TOKEN=...

# --- X (Twitter) Credentials ---
X_USERNAME=your_x_username
X_PASSWORD=your_x_password

# --- Instagram Credentials ---
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# --- Facebook Credentials ---
FACEBOOK_USERNAME=your_facebook_email
FACEBOOK_PASSWORD=your_facebook_password

# --- Pinterest Credentials ---
PINTEREST_USERNAME=your_pinterest_email
PINTEREST_PASSWORD=your_pinterest_password

# --- LinkedIn Credentials ---
LINKEDIN_USERNAME=your_linkedin_email
LINKEDIN_PASSWORD=your_linkedin_password
